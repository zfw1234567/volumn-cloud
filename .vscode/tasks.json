{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "F:\\vscode\\x86_64-15.1.0-release-posix-seh-ucrt-rt_v12-rev0\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I", "F:/vscode/x86_64-15.1.0-release-posix-seh-ucrt-rt_v12-rev0/mingw64/include",
                "-I", "${workspaceFolder}",
                "${file}",
                //"${workspaceFolder}/*.cpp",
                "${workspaceFolder}/vulkanCommandPool/*.cpp",
                "${workspaceFolder}/vulkanContext/*.cpp",
                "${workspaceFolder}/vulkanImageResource/*.cpp",
                "${workspaceFolder}/vulkanRender/*.cpp",
                "${workspaceFolder}/vulkanRenderObject/*.cpp",
                "${workspaceFolder}/stb_impl/*.cpp",
                "${workspaceFolder}/camera/*.cpp",
                "${workspaceFolder}/vulkanCompute/*.cpp",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-lglfw3",
                "-lvulkan-1",
                "-lgdi32",
                "-lopengl32"
